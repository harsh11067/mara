# ─── MARA Dashboard Configuration ──────────────────────────────────────────────

# The dashboard proxies all /api and /ws requests to the MARA backend.
# By default, it expects the backend to be running on http://localhost:3001.

# Port to run the dashboard development server on
VITE_PORT=3000

# To point the dashboard to a remote backend, update the proxy in vite.config.ts.
