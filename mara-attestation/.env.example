# The private key of the wallet that DEPLOYS and OPERATES the contract.
#
# SINGLE SOURCE OF TRUTH: this key MUST derive to SODEX_MASTER_ADDRESS — the
# same wallet that executes trades on SoDEX. deploy.ts will REFUSE to deploy
# if the deployer is not the expected operator (and rejects the Hardhat
# default account outright). Same wallet = same operator = one trust anchor.
DEPLOYER_PRIVATE_KEY=0xYourOperatorPrivateKey

# Optional: pin the expected operator explicitly (defaults to SODEX_MASTER_ADDRESS).
# EXPECTED_OPERATOR=0x2633a0d83a2aA43449DAd7a304a0EE71F5Bfa8eC

# ValueChain network RPC endpoints
VALUECHAIN_TESTNET_RPC=https://testnet.valuechain.xyz
VALUECHAIN_MAINNET_RPC=https://mainnet.valuechain.xyz

# ValueChain block explorer API key (for `npm run verify:testnet`)
VALUECHAIN_EXPLORER_API_KEY=

# Populated automatically after deployment (by deploy.ts output)
MARA_CONTRACT_ADDRESS=
