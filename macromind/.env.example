# ─── MARA Backend Configuration ────────────────────────────────────────────────

# SoSoValue Terminal API Key
# Get one at: https://sosovalue.com/
SOSOVALUE_API_KEY=your_sosovalue_api_key_here

# SoDEX Exchange Access (Testnet)
# Endpoint for public and private trading operations
SODEX_ENDPOINT=https://testnet-gw.sodex.dev/api/v1
SODEX_WS_ENDPOINT=wss://testnet-gw.sodex.dev/ws
SODEX_CHAIN_ID=138565

# Your master wallet address (the account that holds testnet USDC)
SODEX_MASTER_ADDRESS=0xYourWalletAddress

# API key name you created in SoDEX UI (e.g. "macromind-agent")
# If you are using the master wallet key directly, set this to the same address as above
SODEX_API_KEY_NAME=macromind-agent

# Private key of the wallet you used to CREATE the API key on SoDEX
# (Or the master wallet private key if signing directly)
SODEX_API_KEY_PRIVATE=0xYourAPIKeyPrivateKey

# Your SoDEX account ID (visible in the UI after connecting wallet)
SODEX_ACCOUNT_ID=12345

# Google Gemini AI API Key
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# App Server Settings
PORT=3001
DASHBOARD_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Risk Management Overrides (Optional) ───────────────────────────────────
# Defaults are 2% risk, 5x leverage, 5% drawdown
# MAX_RISK_PER_TRADE=0.02
# MAX_LEVERAGE=5
# MAX_DRAWDOWN=0.05

# ─── On-Chain Attestation (ValueChain) ────────────────────────────────────────
# SINGLE SOURCE OF TRUTH: the on-chain operator == SODEX_MASTER_ADDRESS.
# The attestation signer REUSES SODEX_API_KEY_PRIVATE (above), so the wallet
# that signs trades is the same wallet that owns the contract. No separate
# deploy/operator key is configured here. (Optional override: OPERATOR_PRIVATE_KEY)
#
# Address of the MARAAttestation contract. Filled by: cd mara-attestation && npm run deploy:testnet
MARA_CONTRACT_ADDRESS=

# ValueChain RPC (same chainId as SODEX_CHAIN_ID=138565)
#   ValueChain testnet: https://testnet.valuechain.xyz
#   Local dev node:     http://127.0.0.1:8545
VALUECHAIN_RPC=https://testnet.valuechain.xyz

# ─── Wave 3 additions ─────────────────────────────────────────────────────────
# Neon Postgres pooled connection string — enables snapshot persistence across
# Render redeploys (leave unset for local-only SQLite)
DATABASE_URL=

# Telegram signal broadcast (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
